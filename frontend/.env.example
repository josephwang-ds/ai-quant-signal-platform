# Backend API base URL. Public browser configuration; never put secrets here.
# Local development may omit this variable and uses http://127.0.0.1:8000 only.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Production (Vercel) requires an explicit absolute http/https URL.
# A trailing slash is optional and normalized.
# NEXT_PUBLIC_API_BASE_URL=https://ai-quant-signal-platform.onrender.com
