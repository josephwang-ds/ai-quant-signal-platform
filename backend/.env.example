# Comma-separated browser origins for CORS (required on Render).
# Use origins only, without paths. Trailing slashes are normalized.
# Wildcards are rejected. Include the exact deployed Vercel origin.
# Production: https://your-app.vercel.app,https://www.your-domain.com
# Local defaults include localhost/127.0.0.1 on ports 3000 and 3001.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase Postgres connection string for durable legacy backtest records.
# Use the Transaction Pooler URI from Supabase Connect.
# Do not commit real credentials.
SUPABASE_DB_URL=

# Render injects PORT automatically; local development can omit it.
# PORT=8000

# Research Copilot — backend-only OpenAI-compatible Chat Completions.
# Exactly one provider per deployment. No failover. Never use NEXT_PUBLIC_*.
#
# OpenAI example:
# LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# COPILOT_MODEL=gpt-4o-mini
#
# DeepSeek example:
# LLM_PROVIDER=deepseek
# LLM_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com
# COPILOT_MODEL=deepseek-v4-flash
#
# LLM_PROVIDER=
# LLM_API_KEY=
# LLM_BASE_URL=
# COPILOT_MODEL=
#
# Deprecated temporary fallback (prefer LLM_API_KEY):
# OPENAI_API_KEY=
